{
  "name": "@sendlit/api-contract",
  "version": "0.1.0",
  "description": "Shared ts-rest contract (Zod schemas + route definitions) for the SendLit API \u2014 single source of truth for server validation, the OpenAPI doc, and the typed web client",
  "author": "SendLit",
  "license": "MIT",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "clean": "rimraf dist/",
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "rimraf": "^4.1.1",
    "tsup": "6.6.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ts-rest/core": "^3.52.1",
    "zod": "^3.25.76"
  }
}
