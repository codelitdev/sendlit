{
    "name": "@sendlit/api",
    "version": "0.1.0",
    "private": true,
    "description": "Better Auth protected REST API for composing, sending and automating email — the SendLit backend",
    "license": "AGPL-3.0-or-later",
    "main": "dist/src/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "nodemon --exec 'node --env-file=.env --import tsx' src/index.ts",
        "start": "node dist/src/index.js",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc -p tsconfig.test.json"
    },
    "dependencies": {
        "@better-auth/oauth-provider": "^1.6.23",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@sendlit/api-contract": "workspace:*",
        "@sendlit/email-editor": "workspace:*",
        "@ts-rest/express": "^3.52.1",
        "@ts-rest/open-api": "^3.52.1",
        "better-auth": "^1.6.23",
        "bullmq": "^5.34.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.2",
        "express": "^4.21.2",
        "express-rate-limit": "^7.5.0",
        "ioredis": "^5.4.1",
        "jsdom": "^25.0.1",
        "jsonwebtoken": "^9.0.2",
        "liquidjs": "^10.19.0",
        "nanoid": "^5.1.6",
        "nodemailer": "^9.0.1",
        "pg": "^8.13.1",
        "pino": "^10.1.0",
        "swagger-ui-express": "^5.0.1",
        "uuidv7": "^1.0.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.2.17",
        "@types/cors": "^2.8.12",
        "@types/express": "^4.17.20",
        "@types/jsdom": "^21.1.7",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.14.1",
        "@types/nodemailer": "^6.4.17",
        "@types/pg": "^8.11.10",
        "@types/swagger-ui-express": "^4.1.8",
        "drizzle-kit": "^0.28.1",
        "nodemon": "^3.1.10",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^4.1.9"
    }
}
