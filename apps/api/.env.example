# Postgres connection string
DB_CONNECTION_STRING=postgres://sendlit:sendlit@localhost:5432/sendlit

# Redis (used by BullMQ for mail sending + sequence delivery)
REDIS_HOST=localhost
REDIS_PORT=6379

PORT=5000
NODE_ENV=development

# Public URL Better Auth uses for OAuth callbacks, issuers and trusted origins.
API_PUBLIC_URL=http://localhost:5000

# OAuth2 JWT signing key — must be at least 32 bytes. Generate with:
#   openssl rand -base64 48
OAUTH_SIGNING_KEY=

# Used to sign open/click tracking pixel tokens.
PIXEL_SIGNING_SECRET=

# The dashboard's own public origin (apps/web). Used to build Better Auth's
# trusted origins and to allowlist the `redirect` param on this API's hosted
# `/login` page (see apps/web's WEB_CLIENT and the "Unified Login Screen"
# addendum in docs/replace-oauth-server-with-better-auth.md).
WEB_CLIENT=http://localhost:3000

# Optional: parent domain shared by apps/web and apps/api in production
# (e.g. sendlit.example.com, covering both app.sendlit.example.com and
# api.sendlit.example.com). When set, the Better Auth session cookie is
# scoped to this domain instead of being host-only, so a session started on
# either subdomain's login page is valid on both. Leave unset in local dev.
AUTH_COOKIE_DOMAIN=

# Encrypts per-team ESP (SMTP) credentials at rest (AES-256-GCM). Must decode
# to 32 bytes (base64) or contain at least 32 bytes (utf8). Generate with:
#   openssl rand -base64 32
ESP_CREDENTIALS_ENCRYPTION_KEY=

# Used to build tracking-pixel/click/unsubscribe links embedded in outgoing mail.
PROTOCOL=https
DOMAIN=

# HMAC key for the suppression-list recipient fingerprint (never an unsalted
# hash — see docs/bounces-and-complaints.md#8-suppression-model). At least
# 32 bytes. Generate with: openssl rand -base64 32
SUPPRESSION_HASH_KEY=

# Platform mail transport for system email such as login OTPs. Campaign,
# broadcast, sequence and ESP test mail require each team to configure its own
# ESP in settings.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Optional: on boot, if set and no account exists for this email yet, creates
# one (with its default team + API key) and logs the key once — a dev/
# self-host convenience, mirroring MediaLit's admin-bootstrap script. See
# src/bootstrap.ts.
SUPER_ADMIN_EMAIL=

# Required to use POST /provisioning/teams — the server-to-server endpoint a
# multi-tenant consumer (e.g. CourseLit) uses to provision one SendLit team
# per one of its own tenants. Generate a long random value and configure it
# identically on both sides. See src/provisioning/routes.ts.
PROVISIONING_SECRET=

# Optional: PostHog error tracking, product analytics and log shipping.
# When POSTHOG_API_KEY is set, all pino logs (src/services/log.ts) at
# POSTHOG_LOG_LEVEL and above are also shipped to PostHog via OTLP, and
# errors/events are captured via src/observability/posthog.ts. When unset,
# telemetry is fully disabled and logs go to stdout only.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Minimum level shipped to PostHog (default info). stdout level is LOG_LEVEL.
POSTHOG_LOG_LEVEL=
# Max captured errors per source per minute (default 100).
POSTHOG_ERROR_CAP_PER_SOURCE_PER_MINUTE=
# Reported as the deployment environment (falls back to NODE_ENV).
DEPLOY_ENV=

# MediaLit integration for file uploads
MEDIALIT_APIKEY=
MEDIALIT_SERVER=https://api.medialit.cloud

# Credentials for sign in with login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
