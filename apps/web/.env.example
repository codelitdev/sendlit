# The base URL of the SendLit API (apps/api). Server-side only — never exposed
# to the browser. All requests from the browser go through this app's own
# /api/proxy route, which attaches the access token.
API_URL=http://localhost:4000

# Must match this app's own origin — used to build the OAuth redirect_uri and
# must be registered on the API's "web-client" (see apps/api's WEB_CLIENT env var).
WEB_CLIENT=http://localhost:3000
