# The base URL of the SendLit API (apps/api). Server-side only — never exposed
# to the browser. All requests from the browser go through this app's own
# /api/proxy route, which forwards the session cookie as-is.
API_URL=http://localhost:5000

# Must match this app's own public origin. Sent to the API's hosted /login
# page as the `redirect` target after sign-in — must match the API's own
# WEB_CLIENT env var, which allowlists it.
WEB_CLIENT=http://localhost:3000

# Maximum size (in bytes) accepted for image uploads in the email image
# picker. Defaults to 10MB if unset.
MAX_UPLOAD_SIZE=10485760
